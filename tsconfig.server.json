{
    "extends": "./tsconfig.base.json",
    "typedocOptions": {
        "out": "docs"
    },
    "compilerOptions": {
        "rootDir": "./src/main/ts",
        "outDir": "./dist/js",
        "moduleResolution": "nodenext",
        "module": "nodenext",
        "target": "esnext",
        "lib": [
            "ESNext",
            "DOM",
        ],
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "types": [
            "node",
        ]
    },
    "include": [
        "src/main/ts/**/*",
    ]
}